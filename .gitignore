# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.python-version

# uv
uv.lock

# Editors / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Outputs (large files generated by experiments)
outputs/steering_vectors/*.pt
outputs/rollouts/*.jsonl
outputs/judgements/*.json
outputs/judgements/*.jsonl
outputs/logs/*.log
outputs/logs/*.out
outputs/logs/*.err

# Allow keeping the output dirs themselves
!outputs/steering_vectors/.gitkeep
!outputs/rollouts/.gitkeep
!outputs/judgements/.gitkeep
!outputs/logs/.gitkeep
