# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.python-version

# uv
uv.lock

# Editors / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Outputs (large files generated by experiments — ignore everything, keep dirs)
outputs/steering_vectors/*
outputs/rollouts/*
outputs/judgements/*
outputs/logs/*
!outputs/steering_vectors/.gitkeep
!outputs/rollouts/.gitkeep
!outputs/judgements/.gitkeep
!outputs/logs/.gitkeep

# Finetuning checkpoints (LoRA adapters — can be large)
outputs/checkpoints/
!outputs/checkpoints/.gitkeep

# Generated training / test data (reproducible from source files)
data/finetune_train.jsonl
data/gsm8k_test.jsonl

# Model weights (never commit)
models/
*.safetensors
*.bin
*.gguf
